{
  "manifest_version": 3,
  "name": "IA² Navigator",
  "version": "0.1.0",
  "description": "Inspect HTML/RDF datasets and browse verified files in HARE resource envelopes.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "content_scripts": [
    {
      "js": [
        "auto.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "js": [
        "status.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_idle",
      "world": "ISOLATED"
    }
  ],
  "action": {
    "default_title": "Open IA² Navigator",
    "default_icon": {
      "16": "icons/ia2-mark-16.png",
      "32": "icons/ia2-mark-32.png"
    }
  },
  "icons": {
    "16": "icons/ia2-mark-16.png",
    "32": "icons/ia2-mark-32.png",
    "48": "icons/ia2-mark-48.png",
    "128": "icons/ia2-mark-128.png",
    "512": "icons/ia2-mark-512.png"
  }
}
