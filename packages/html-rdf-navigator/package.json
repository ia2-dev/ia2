{
  "name": "@ia2-dev/html-rdf-navigator",
  "version": "0.1.2",
  "description": "A live RDF dataset navigator and inspector for IA² HTML/RDF documents.",
  "author": "Yurii Rashkovskii",
  "homepage": "https://ia2.dev/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ia2-dev/ia2.git",
    "directory": "packages/html-rdf-navigator"
  },
  "bugs": {
    "url": "https://github.com/ia2-dev/ia2/issues"
  },
  "type": "module",
  "sideEffects": true,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/html-rdf-navigator.js",
      "default": "./dist/html-rdf-navigator.js"
    }
  },
  "main": "./dist/html-rdf-navigator.js",
  "module": "./dist/html-rdf-navigator.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.build.json && esbuild src/index.ts --bundle --format=esm --platform=browser --target=es2022 --outfile=dist/html-rdf-navigator.js --sourcemap=external",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "rdf",
    "rdfjs",
    "html",
    "linked-data",
    "turtle",
    "json-ld",
    "ia2",
    "web-component"
  ],
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.25.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
