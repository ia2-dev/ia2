@prefix rdfhtml: <https://ia2.dev/spec/rdf-html#> .
@prefix ex: <https://example.test/rdf-html/conformance/> .

ex:missing a rdfhtml:Document ;
    rdfhtml:base <https://example.test/rendered/> ;
    rdfhtml:children ( ex:html ) .
ex:html a rdfhtml:Html ; rdfhtml:children ( ex:head ex:body ) .
ex:head a rdfhtml:Head .
ex:body a rdfhtml:Body .
